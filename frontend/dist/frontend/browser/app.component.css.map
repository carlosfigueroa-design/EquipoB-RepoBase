
    .app-shell {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .app-body {
      display: flex;
      flex: 1;
    }

    .app-content {
      flex: 1;
      padding: var(--sb-ui-spacing-lg, 24px);
      background-color: var(--sb-ui-bg-primary, #f5f7fa);
      overflow-y: auto;
    }
  